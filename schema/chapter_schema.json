{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChapterKnowledge",
  "type": "object",
  "required": ["book", "chapter", "topics"],
  "properties": {
    "book": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" }
      }
    },
    "chapter": {
      "type": "object",
      "required": ["number", "title"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" }
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "subtopics"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "subtopics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "concepts"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "concepts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title"],
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "definition": { "type": "string" },
                      "facts": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "keywords": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "related": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "learning_objectives": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "exam_metadata": {
                        "type": "object",
                        "properties": {
                          "importance": { "type": "string", "enum": ["low", "medium", "high"] },
                          "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
                          "mcq_patterns": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "common_misconceptions": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "pyq_themes": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
